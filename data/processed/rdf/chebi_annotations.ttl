obo:CHEBI_51068  rdf:type               owl:Class;
        rdfs:label                      "miotic";
        rdfs:subClassOf                 obo:CHEBI_35942;
        obo:IAO_0000115                 "An agent causing contraction of the pupil of the eye. Because the size of the pupil is under the antagonistic control of the sympathetic and parasympathetic systems, drugs affecting either system can cause miosis. Drugs that mimic or potentiate the parasympathetic input to the circular constrictor muscle and drugs that inhibit sympathetic input to the radial dilator muscle tend to contract the pupils.";
        geneontology:hasOBONamespace    "chebi_ontology";
        geneontology:hasRelatedSynonym  "Miotico" , "miotics";
        geneontology:id                 "CHEBI:51068";
        geneontology:inSubset           chebi:3_STAR .

