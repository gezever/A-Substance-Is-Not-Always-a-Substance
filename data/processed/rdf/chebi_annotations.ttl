obo:CHEBI_35493  rdf:type               owl:Class;
        rdfs:label                      "antipyretic";
        rdfs:subClassOf                 obo:CHEBI_23888;
        obo:IAO_0000115                 "A drug that prevents or reduces fever by lowering the body temperature from a raised state. An antipyretic will not affect the normal body temperature if one does not have fever. Antipyretics cause the hypothalamus to override an interleukin-induced increase in temperature. The body will then work to lower the temperature and the result is a reduction in fever.";
